---
---

<section id="contact" class="py-32 relative bg-brand-50 border-t border-brand-100 overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
        
        <div class="glass-card rounded-3xl overflow-hidden shadow-2xl shadow-brand-500/10 border-brand-200">
            <div class="grid md:grid-cols-2">
                
                <!-- Value Prop Side -->
                <div class="p-12 md:p-16 bg-slate-900 text-white relative overflow-hidden">
                    <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI4IiBoZWlnaHQ9IjgiPgo8cmVjdCB3aWR0aD0iOCIgaGVpZ2h0PSI4IiBmaWxsPSIjZmZmIiBmaWxsLW9wYWNpdHk9IjAuMDUiPjwvcmVjdD4KPHBhdGggZD0iTTAgMEw4IDhaTTggMEwwIDhaIiBzdHJva2U9IiMwMDAiIHN0cm9rZS1vcGFjaXR5PSIwLjA1Ij48L3BhdGg+Cjwvc3ZnPg==')] opacity-20"></div>
                    <div class="absolute -top-32 -left-32 w-96 h-96 bg-brand-500 rounded-full blur-[120px] opacity-40 mix-blend-screen pointer-events-none"></div>
                    <div class="absolute -bottom-32 -right-32 w-96 h-96 bg-blue-500 rounded-full blur-[120px] opacity-40 mix-blend-screen pointer-events-none"></div>
                    
                    <div class="relative z-10">
                        <h2 class="font-display text-4xl font-bold mb-6 leading-tight">
                            讓 AI 成為您的專屬 SEO 行銷顧問
                        </h2>
                        <p class="text-brand-100 text-lg mb-10 font-light leading-relaxed">
                            不再依賴人工猜測關鍵字與排名。透過數據驅動的自動化系統，從建站到變現，為您打造源源不絕的被動流量池。
                        </p>
                        
                        <div class="space-y-6">
                            <div class="flex items-center gap-4">
                                <div class="w-12 h-12 rounded-full bg-white/10 flex items-center justify-center backdrop-blur-sm border border-white/20">
                                    <svg class="w-6 h-6 text-brand-200" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
                                </div>
                                <div>
                                    <h3 class="font-bold text-lg">快速上線</h3>
                                    <p class="text-brand-200 text-sm">數天內部署高轉換率 SEO 網站</p>
                                </div>
                            </div>
                            
                            <div class="flex items-center gap-4">
                                <div class="w-12 h-12 rounded-full bg-white/10 flex items-center justify-center backdrop-blur-sm border border-white/20">
                                    <svg class="w-6 h-6 text-brand-200" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
                                </div>
                                <div>
                                    <h3 class="font-bold text-lg">保證排名成長</h3>
                                    <p class="text-brand-200 text-sm">數據監測確保字詞排名穩定上升</p>
                                </div>
                            </div>
                            
                            <div class="flex items-center gap-4">
                                <div class="w-12 h-12 rounded-full bg-white/10 flex items-center justify-center backdrop-blur-sm border border-white/20">
                                    <svg class="w-6 h-6 text-brand-200" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
                                </div>
                                <div>
                                    <h3 class="font-bold text-lg">專注 B2B 市場</h3>
                                    <p class="text-brand-200 text-sm">深度解析決策者意圖，提高成交機率</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div id="form-container" class="p-12 md:p-16 bg-white relative">
                    <div id="form-header">
                        <h3 class="text-2xl font-bold text-slate-900 mb-2">預約免費諮詢與網站健檢</h3>
                        <p class="text-slate-500 mb-8 font-light">請填寫下方表單，我們的專業顧問將在 24 小時內與您聯繫。</p>
                    </div>
                    
                    <form id="lead-form" class="space-y-6">
                        <div class="grid grid-cols-2 gap-6">
                            <div>
                                <label for="lastName" class="block text-sm font-medium text-slate-700 mb-2">姓氏</label>
                                <input type="text" id="lastName" name="lastName" required class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none transition-all bg-slate-50 focus:bg-white text-slate-900">
                            </div>
                            <div>
                                <label for="firstName" class="block text-sm font-medium text-slate-700 mb-2">名字</label>
                                <input type="text" id="firstName" name="firstName" required class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none transition-all bg-slate-50 focus:bg-white text-slate-900">
                            </div>
                        </div>
                        
                        <div>
                            <label for="email" class="block text-sm font-medium text-slate-700 mb-2">公司信箱</label>
                            <input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none transition-all bg-slate-50 focus:bg-white text-slate-900">
                        </div>
                        
                        <div>
                            <label for="company" class="block text-sm font-medium text-slate-700 mb-2">公司名稱 / 網站網址</label>
                            <input type="text" id="company" name="company" class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none transition-all bg-slate-50 focus:bg-white text-slate-900">
                        </div>
                        
                        <div>
                            <label for="message" class="block text-sm font-medium text-slate-700 mb-2">您想解決的問題</label>
                            <textarea id="message" name="message" rows="4" class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none transition-all bg-slate-50 focus:bg-white text-slate-900 resize-none"></textarea>
                        </div>
                        
                        <div id="form-error" class="hidden text-red-500 text-sm text-center"></div>

                        <button id="submit-btn" type="submit" class="w-full py-4 px-6 text-center rounded-xl bg-slate-900 hover:bg-slate-800 text-white font-bold transition-all shadow-xl shadow-slate-900/20 text-lg group ring-1 ring-slate-900/10 flex items-center justify-center">
                            <span id="btn-text">送出預約</span>
                            <span id="btn-arrow" class="inline-block transition-transform group-hover:translate-x-1 ml-1">→</span>
                            <svg id="btn-spinner" class="hidden animate-spin ml-2 h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                            </svg>
                        </button>
                        <p class="text-xs text-slate-500 text-center mt-4">我們尊重您的隱私，絕不向第三方透露您的資料。</p>
                    </form>

                    <div id="success-message" class="hidden h-full flex-col items-center justify-center text-center space-y-4 py-12">
                        <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center text-green-500 mb-4">
                            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        </div>
                        <h3 class="text-2xl font-bold text-slate-900">預約成功！</h3>
                        <p class="text-slate-500">我們已收到您的資訊，專業顧問將在 24 小時內與您聯繫。</p>
                        <button id="reset-btn" class="mt-6 px-6 py-2 border border-slate-200 rounded-lg text-slate-600 hover:bg-slate-50 transition-colors">
                            回上一步
                        </button>
                    </div>
                </div>
                
            </div>
        </div>
    </div>
</section>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const form = document.getElementById('lead-form') as HTMLFormElement;
        const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
        const btnText = document.getElementById('btn-text');
        const btnArrow = document.getElementById('btn-arrow');
        const btnSpinner = document.getElementById('btn-spinner');
        const successMessage = document.getElementById('success-message');
        const resetBtn = document.getElementById('reset-btn');
        const formError = document.getElementById('form-error');

        // Allow overriding the API URL for local dev vs production
        const API_URL = import.meta.env.PUBLIC_API_URL || 'https://api.stacksuite.dev';

        if (form && submitBtn) {
            form.addEventListener('submit', async (e) => {
                e.preventDefault();
                
                // Reset state
                if (formError) {
                    formError.classList.add('hidden');
                    formError.textContent = '';
                }
                
                // Set loading state
                submitBtn.disabled = true;
                submitBtn.classList.add('opacity-75', 'cursor-not-allowed');
                if (btnText) btnText.textContent = '處理中...';
                if (btnArrow) btnArrow.classList.add('hidden');
                if (btnSpinner) btnSpinner.classList.remove('hidden');

                const formData = new FormData(form);
                const lastName = (formData.get('lastName') as string).trim();
                const firstName = (formData.get('firstName') as string).trim();
                const email = (formData.get('email') as string).trim();
                const company = (formData.get('company') as string).trim();
                const message = (formData.get('message') as string).trim();

                // Differentiate between company name and website URL
                let companyName = company;
                let websiteUrl = '';
                
                // Basic heuristic: if it has no spaces and contains a dot or starts with http, it's likely a URL
                const isLikelyUrl = company && !company.includes(' ') && (company.includes('.') || company.startsWith('http'));
                
                if (isLikelyUrl) {
                    websiteUrl = company.startsWith('http') ? company : `https://${company}`;
                    companyName = '';
                }

                try {
                    const response = await fetch(`${API_URL}/v1/leads`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify({
                            name: `${lastName}${firstName}`,
                            email,
                            companyName: companyName || undefined,
                            websiteUrl: websiteUrl || undefined,
                            message: message || undefined,
                            source: 'ai-website-seo-service'
                        })
                    });

                    const result = await response.json();

                    if (!response.ok) {
                        throw new Error(result.error?.message || '傳送失敗，請稍後再試。');
                    }

                    // Success!
                    form.classList.add('hidden');
                    const formHeader = document.getElementById('form-header');
                    if (formHeader) formHeader.classList.add('hidden');
                    if (successMessage) successMessage.classList.remove('hidden');
                    successMessage.classList.add('flex');
                    form.reset();

                } catch (error: any) {
                    console.error('Lead submission error:', error);
                    if (formError) {
                        formError.textContent = error.message || '發生未知錯誤，請稍後再試。';
                        formError.classList.remove('hidden');
                    }
                } finally {
                    // Reset loading state
                    submitBtn.disabled = false;
                    submitBtn.classList.remove('opacity-75', 'cursor-not-allowed');
                    if (btnText) btnText.textContent = '送出預約';
                    if (btnArrow) btnArrow.classList.remove('hidden');
                    if (btnSpinner) btnSpinner.classList.add('hidden');
                }
            });
        }

        if (resetBtn) {
            resetBtn.addEventListener('click', () => {
                if (successMessage) {
                    successMessage.classList.add('hidden');
                    successMessage.classList.remove('flex');
                }
                const formHeader = document.getElementById('form-header');
                if (formHeader) formHeader.classList.remove('hidden');
                if (form) form.classList.remove('hidden');
            });
        }
    });
</script>