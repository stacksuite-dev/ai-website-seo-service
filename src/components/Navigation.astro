<nav class="fixed top-0 left-0 right-0 z-[60] glass-nav transition-all duration-300" id="main-nav">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="flex justify-between h-20 items-center">
            <a href="/" class="flex items-center gap-3 relative z-[70]">
                <svg width="28" height="28" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="2" y="2" width="12" height="12" rx="3" fill="#0f172a" fill-opacity="0.9"/>
                    <rect x="18" y="2" width="12" height="28" rx="3" fill="#3b82f6" fill-opacity="0.9"/>
                    <rect x="2" y="18" width="12" height="12" rx="3" fill="#10b981" fill-opacity="0.9"/>
                </svg>
                <span class="font-display font-bold text-xl tracking-wide text-slate-900">AI SEO 專家</span>
            </a>
            
            <!-- Desktop Nav -->
            <div class="hidden md:flex items-center gap-8 relative z-[70]">
                <a href="/#process" class="text-sm font-medium text-slate-600 hover:text-brand-600 transition-colors tracking-wide">運作流程</a>
                <a href="/showcase" class="text-sm font-medium text-slate-600 hover:text-brand-600 transition-colors tracking-wide">實戰案例</a>
                <a href="/#pricing" class="text-sm font-medium text-slate-600 hover:text-brand-600 transition-colors tracking-wide">收費方案</a>
                <a href="/blog" class="text-sm font-medium text-slate-600 hover:text-brand-600 transition-colors tracking-wide">SEO 專欄</a>
                <a href="/#contact" class="inline-flex items-center justify-center bg-slate-900 hover:bg-slate-800 text-white px-6 py-2.5 rounded-full text-sm font-bold transition-all shadow-lg hover:shadow-xl hover:-translate-y-0.5">
                    立即預約
                </a>
            </div>

            <!-- Mobile Hamburger Button -->
            <button id="mobile-menu-btn" class="md:hidden relative z-[70] w-10 h-10 flex flex-col justify-center items-end gap-1.5 text-slate-900 group cursor-pointer border-none bg-transparent" aria-label="Toggle Menu">
                <span class="w-6 h-[2px] bg-current transform transition-all duration-300 origin-right line-1 rounded-full"></span>
                <span class="w-4 h-[2px] bg-current transform transition-all duration-300 origin-right line-2 rounded-full group-hover:w-6"></span>
            </button>
        </div>
    </div>
</nav>

<!-- Mobile Menu Drawer -->
<div id="mobile-backdrop" class="fixed inset-0 bg-slate-900/20 backdrop-blur-sm z-[40] opacity-0 pointer-events-none transition-opacity duration-500 md:hidden"></div>

<div id="mobile-drawer" class="fixed top-0 right-0 w-full max-w-[85vw] sm:max-w-sm h-[100dvh] bg-white/90 backdrop-blur-3xl z-[50] transform translate-x-full transition-transform duration-500 ease-[cubic-bezier(0.4,0,0.2,1)] border-l border-white/50 shadow-[0_0_40px_rgba(0,0,0,0.1)] flex flex-col md:hidden">
    
    <!-- Spacer for the fixed header -->
    <div class="h-20 shrink-0 border-b border-slate-100 flex items-center justify-between px-8">
        <span class="font-display font-bold text-sm tracking-widest text-slate-400 uppercase">MENU</span>
    </div>
    
    <div class="flex-1 overflow-y-auto py-8 px-8 flex flex-col justify-center gap-8">
        <a href="/#process" class="mobile-link group flex items-center justify-between text-3xl font-display font-bold text-slate-800 hover:text-brand-600 transition-colors">
            <span>運作流程</span>
            <span class="opacity-0 -translate-x-4 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 text-brand-500">→</span>
        </a>
        <a href="/showcase" class="mobile-link group flex items-center justify-between text-3xl font-display font-bold text-slate-800 hover:text-brand-600 transition-colors">
            <span>實戰案例</span>
            <span class="opacity-0 -translate-x-4 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 text-brand-500">→</span>
        </a>
        <a href="/#pricing" class="mobile-link group flex items-center justify-between text-3xl font-display font-bold text-slate-800 hover:text-brand-600 transition-colors">
            <span>收費方案</span>
            <span class="opacity-0 -translate-x-4 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 text-brand-500">→</span>
        </a>
        <a href="/blog" class="mobile-link group flex items-center justify-between text-3xl font-display font-bold text-slate-800 hover:text-brand-600 transition-colors">
            <span>SEO 專欄</span>
            <span class="opacity-0 -translate-x-4 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 text-brand-500">→</span>
        </a>
    </div>
    
    <div class="p-8 pb-12 flex flex-col gap-4 relative">
        <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-slate-200 to-transparent"></div>
        <button class="w-full bg-slate-100 hover:bg-slate-200 text-slate-700 px-6 py-4 rounded-2xl text-base font-bold transition-colors">登入系統</button>
        <a href="/#contact" class="mobile-link w-full text-center bg-slate-900 hover:bg-slate-800 text-white px-6 py-4 rounded-2xl text-base font-bold transition-all shadow-xl shadow-slate-900/20">立即開始</a>
    </div>
</div>

<style>
    /* Glass Nav default styles (assuming global.css provides .glass-nav) */
    nav.glass-nav {
        background: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-bottom: 1px solid rgba(255,255,255,0.3);
    }

    /* Hamburger Animation to Close (X) */
    #mobile-menu-btn.menu-open .line-1 {
        transform: rotate(-45deg) translate(-4px, 4px);
        width: 24px;
    }
    #mobile-menu-btn.menu-open .line-2 {
        transform: rotate(45deg) translate(-3px, -3px);
        width: 24px;
    }
</style>

<script>
    // Component script for mobile menu toggle
    document.addEventListener('DOMContentLoaded', () => {
        const btn = document.getElementById('mobile-menu-btn');
        const drawer = document.getElementById('mobile-drawer');
        const backdrop = document.getElementById('mobile-backdrop');
        const links = document.querySelectorAll('.mobile-link');
        let isOpen = false;

        function toggleMenu() {
            isOpen = !isOpen;
            if (isOpen) {
                drawer?.classList.remove('translate-x-full');
                backdrop?.classList.remove('opacity-0', 'pointer-events-none');
                btn?.classList.add('menu-open');
                document.body.style.overflow = 'hidden'; // Prevent background scrolling
            } else {
                drawer?.classList.add('translate-x-full');
                backdrop?.classList.add('opacity-0', 'pointer-events-none');
                btn?.classList.remove('menu-open');
                document.body.style.overflow = '';
            }
        }

        btn?.addEventListener('click', toggleMenu);
        backdrop?.addEventListener('click', toggleMenu);
        
        // Close menu when a link is clicked
        links.forEach(link => {
            link.addEventListener('click', () => {
                if(isOpen) toggleMenu();
            });
        });
    });
</script>
