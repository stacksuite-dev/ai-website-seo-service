---

<section class="relative pt-40 pb-24 lg:pt-48 lg:pb-32 min-h-[90vh] flex items-center">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 w-full">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
            
            <!-- Left: Typography & Copy -->
            <div class="max-w-2xl opacity-0 animate-fade-in-up">
                <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-brand-500/30 bg-brand-50 text-brand-600 text-xs font-bold tracking-widest mb-8">
                    <span class="w-2 h-2 rounded-full bg-brand-500 animate-pulse"></span>
                    新世代 SEO 自動化技術
                </div>
                <h1 class="font-display text-5xl sm:text-6xl lg:text-7xl font-black tracking-tight text-slate-900 mb-6 leading-[1.15]">
                    以 AI 驅動科技<br>
                    <span class="text-gradient-brand">重塑搜尋引擎排名</span>
                </h1>
                <p class="text-lg sm:text-xl text-slate-600 mb-10 leading-relaxed font-light">
                    告別繁瑣的手動優化。只需上傳企業簡報，系統將於數分鐘內自動生成高轉換率的專屬網頁。結合實時效能追蹤與 AI 競爭策略分析，為您全面提升數碼影響力。
                </p>
                <div class="flex flex-col sm:flex-row gap-4">
                    <a href="#contact" class="bg-slate-900 hover:bg-slate-800 text-white px-8 py-4 rounded-full text-base font-bold transition-all shadow-xl shadow-slate-900/20 flex items-center justify-center gap-2 group ring-1 ring-slate-900/10">
                        立即預約
                        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                    </a>
                    <a href="#process" class="glass-card hover:bg-white/80 text-slate-700 px-8 py-4 rounded-full text-base font-medium transition-all flex items-center justify-center gap-2 hover:shadow-lg hover:shadow-slate-200/50">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        了解運作流程
                    </a>
                </div>
            </div>

            <!-- Right: Custom Abstract Data/SEO Graphic -->
            <div class="relative opacity-0 animate-fade-in-up delay-200 lg:ml-auto">
                <!-- Floating Glass Card Effect -->
                <div class="relative w-full max-w-lg aspect-square glass-card rounded-3xl p-8 flex flex-col justify-between animate-float overflow-hidden">
                    
                    <!-- Internal subtle glow -->
                    <div class="absolute inset-0 bg-gradient-to-br from-brand-50 to-transparent opacity-50"></div>
                    
                    <div class="relative z-10 flex justify-between items-start mb-8">
                        <div>
                            <div class="text-xs font-bold tracking-widest text-slate-500 uppercase mb-1">實時預測模型</div>
                            <div class="text-2xl font-display font-bold text-slate-900">SEO 增長趨勢</div>
                        </div>
                        <div class="bg-brand-50 text-brand-600 px-3 py-1 rounded-full text-xs font-bold border border-brand-200">
                            +124%
                        </div>
                    </div>

                    <!-- Custom Drawn SVG Chart -->
                    <div class="relative z-10 flex-grow w-full mt-4">
                        <svg width="100%" height="100%" viewBox="0 0 400 200" fill="none" xmlns="http://www.w3.org/2000/svg" class="overflow-visible svg-chart">
                            <!-- Grid lines -->
                            <path d="M0 40H400M0 100H400M0 160H400" stroke="rgba(0,0,0,0.05)" stroke-width="1" stroke-dasharray="4 4"/>
                            
                            <!-- Glowing Area under the line -->
                            <path class="chart-area" d="M0 160 C 50 160, 80 120, 150 110 C 220 100, 280 140, 320 80 C 360 20, 380 40, 400 10 L 400 200 L 0 200 Z" fill="url(#paint0_linear)"/>
                            
                            <!-- The Main Trend Line -->
                            <path class="chart-line drop-shadow-[0_0_8px_rgba(45,212,191,0.5)]" d="M0 160 C 50 160, 80 120, 150 110 C 220 100, 280 140, 320 80 C 360 20, 380 40, 400 10" stroke="url(#paint1_linear)" stroke-width="4" stroke-linecap="round"/>
                            
                            <!-- Data Nodes -->
                            <circle class="chart-node node-1" cx="150" cy="110" r="5" fill="#fff" stroke="#2dd4bf" stroke-width="3"/>
                            <circle class="chart-node node-2" cx="320" cy="80" r="5" fill="#fff" stroke="#3b82f6" stroke-width="3"/>
                            <circle class="chart-node node-3 drop-shadow-[0_0_12px_rgba(0,0,0,0.2)]" cx="400" cy="10" r="6" fill="#1e293b"/>

                            <defs>
                                <linearGradient id="paint0_linear" x1="200" y1="0" x2="200" y2="200" gradientUnits="userSpaceOnUse">
                                    <stop stop-color="#2dd4bf" stop-opacity="0.15"/>
                                    <stop offset="1" stop-color="#3b82f6" stop-opacity="0"/>
                                </linearGradient>
                                <linearGradient id="paint1_linear" x1="0" y1="85" x2="400" y2="85" gradientUnits="userSpaceOnUse">
                                    <stop stop-color="#2dd4bf"/>
                                    <stop offset="1" stop-color="#3b82f6"/>
                                </linearGradient>
                            </defs>
                        </svg>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    /* SVG Chart Animations */
    .svg-chart {
        --path-length: 650; /* Approximate length of the bezier curve */
    }

    .chart-line {
        stroke-dasharray: var(--path-length);
        stroke-dashoffset: var(--path-length);
        animation: drawLine 2s cubic-bezier(0.4, 0, 0.2, 1) forwards;
        animation-delay: 0.5s; /* Wait for main hero fade-in */
    }

    .chart-area {
        opacity: 0;
        animation: fadeInArea 1.5s ease-out forwards;
        animation-delay: 1.5s; /* Fade in as line finishes drawing */
        transform-origin: bottom;
    }

    .chart-node {
        opacity: 0;
        transform-origin: center;
        transform-box: fill-box;
        animation: popNode 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
    }

    .node-1 { animation-delay: 1.0s; }
    .node-2 { animation-delay: 1.8s; }
    .node-3 { 
        animation: popNode 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards,
                   pulseNode 2s ease-in-out infinite alternate;
        animation-delay: 2.2s, 2.7s; /* pop then pulse */
    }

    @keyframes drawLine {
        to { stroke-dashoffset: 0; }
    }

    @keyframes fadeInArea {
        0% { opacity: 0; transform: scaleY(0.95); }
        100% { opacity: 1; transform: scaleY(1); }
    }

    @keyframes popNode {
        0% { opacity: 0; transform: scale(0); }
        80% { transform: scale(1.2); }
        100% { opacity: 1; transform: scale(1); }
    }

    @keyframes pulseNode {
        0% { transform: scale(1); filter: drop-shadow(0 0 12px rgba(15, 23, 42, 0.2)); }
        100% { transform: scale(1.2); filter: drop-shadow(0 0 20px rgba(15, 23, 42, 0.4)); }
    }
</style>