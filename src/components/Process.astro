---
---

<section id="process" class="py-32 relative border-t border-slate-200 bg-slate-50">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
        
        <div class="text-center max-w-3xl mx-auto mb-20 opacity-0 animate-fade-in-up">
            <h2 class="font-display text-4xl sm:text-5xl font-bold text-slate-900 mb-6">全自動化 AI 運作流程</h2>
            <p class="text-lg text-slate-600 font-light">我們將繁複的網頁建構與 SEO 管理化為極致簡約。從資料匯入到流量變現，一切由強大演算法無縫接管。</p>
        </div>
        
        <!-- Process Grid -->
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
            
            <!-- Step 1 -->
            <div class="glass-card p-8 rounded-2xl group hover:-translate-y-2 transition-all duration-300 opacity-0 animate-fade-in-up delay-100 relative overflow-hidden bg-white/70 hover:bg-white border-white/40 hover:shadow-xl hover:shadow-brand-500/10">
                <div class="absolute top-0 right-0 w-32 h-32 bg-brand-100 rounded-full blur-2xl group-hover:bg-brand-200 transition-colors"></div>
                
                <!-- Custom SVG Icon 1: Ingestion/Data -->
                <svg class="w-10 h-10 mb-6 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                </svg>
                
                <div class="text-brand-600 font-bold text-sm tracking-widest mb-2 uppercase">Phase 01</div>
                <h3 class="text-xl font-bold text-slate-900 mb-3">數據匯入與解析</h3>
                <p class="text-sm text-slate-600 leading-relaxed font-light">上傳您的企業簡報或文件，AI 引擎將瞬間解構並提取品牌核心價值與服務架構。</p>
            </div>

            <!-- Step 2 -->
            <div class="glass-card p-8 rounded-2xl group hover:-translate-y-2 transition-all duration-300 opacity-0 animate-fade-in-up delay-200 relative overflow-hidden bg-white/70 hover:bg-white border-white/40 hover:shadow-xl hover:shadow-brand-500/10">
                <div class="absolute top-0 right-0 w-32 h-32 bg-blue-100 rounded-full blur-2xl group-hover:bg-blue-200 transition-colors"></div>
                
                <!-- Custom SVG Icon 2: AI Analysis / Brain -->
                <svg class="w-10 h-10 mb-6 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                
                <div class="text-blue-600 font-bold text-sm tracking-widest mb-2 uppercase">Phase 02</div>
                <h3 class="text-xl font-bold text-slate-900 mb-3">AI 深度洞察分析</h3>
                <p class="text-sm text-slate-600 leading-relaxed font-light">運用自然語言處理 (NLP) 技術，精準識別目標受眾搜尋意圖與市場藍海缺口。</p>
            </div>

            <!-- Step 3 -->
            <div class="glass-card p-8 rounded-2xl group hover:-translate-y-2 transition-all duration-300 opacity-0 animate-fade-in-up delay-300 relative overflow-hidden bg-white/70 hover:bg-white border-white/40 hover:shadow-xl hover:shadow-brand-500/10">
                <div class="absolute top-0 right-0 w-32 h-32 bg-indigo-100 rounded-full blur-2xl group-hover:bg-indigo-200 transition-colors"></div>
                
                <!-- Custom SVG Icon 3: Structure/Sitemap -->
                <svg class="w-10 h-10 mb-6 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6z" />
                </svg>
                
                <div class="text-indigo-600 font-bold text-sm tracking-widest mb-2 uppercase">Phase 03</div>
                <h3 class="text-xl font-bold text-slate-900 mb-3">網頁架構與生成</h3>
                <p class="text-sm text-slate-600 leading-relaxed font-light">結合專家經驗與演算法，自動構建最具轉換率的網站地圖與高質素 SEO 友善內容。</p>
            </div>

            <!-- Step 4 -->
            <div class="glass-card p-8 rounded-2xl group hover:-translate-y-2 transition-all duration-300 opacity-0 animate-fade-in-up delay-400 relative overflow-hidden bg-white/70 hover:bg-white border-white/40 hover:shadow-xl hover:shadow-brand-500/10">
                <div class="absolute top-0 right-0 w-32 h-32 bg-purple-100 rounded-full blur-2xl group-hover:bg-purple-200 transition-colors"></div>
                
                <!-- Custom SVG Icon 4: Monitoring/Growth -->
                <svg class="w-10 h-10 mb-6 text-purple-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                </svg>
                
                <div class="text-purple-600 font-bold text-sm tracking-widest mb-2 uppercase">Phase 04</div>
                <h3 class="text-xl font-bold text-slate-900 mb-3">機器學習監測</h3>
                <p class="text-sm text-slate-600 leading-relaxed font-light">全天候實時追蹤網站健康度與排名指標。系統將主動提出優化建議，維持您的領先優勢。</p>
            </div>

            <!-- Step 5 -->
            <div class="glass-card p-8 rounded-2xl group hover:-translate-y-2 transition-all duration-300 opacity-0 animate-fade-in-up delay-[500ms] relative overflow-hidden bg-white/70 hover:bg-white border-white/40 hover:shadow-xl hover:shadow-brand-500/10">
                <div class="absolute top-0 right-0 w-32 h-32 bg-teal-100 rounded-full blur-2xl group-hover:bg-teal-200 transition-colors"></div>
                
                <!-- Custom SVG Icon 5: Technical SEO -->
                <svg class="w-10 h-10 mb-6 text-teal-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                
                <div class="text-teal-600 font-bold text-sm tracking-widest mb-2 uppercase">Phase 05</div>
                <h3 class="text-xl font-bold text-slate-900 mb-3">技術 SEO 優化</h3>
                <p class="text-sm text-slate-600 leading-relaxed font-light">自動化處理網站速度、Schema 標記與 Core Web Vitals，確保搜尋引擎爬蟲無障礙抓取。</p>
            </div>

            <!-- Step 6 -->
            <div class="glass-card p-8 rounded-2xl group hover:-translate-y-2 transition-all duration-300 opacity-0 animate-fade-in-up delay-[600ms] relative overflow-hidden bg-white/70 hover:bg-white border-white/40 hover:shadow-xl hover:shadow-brand-500/10">
                <div class="absolute top-0 right-0 w-32 h-32 bg-emerald-100 rounded-full blur-2xl group-hover:bg-emerald-200 transition-colors"></div>
                
                <!-- Custom SVG Icon 6: Content -->
                <svg class="w-10 h-10 mb-6 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                </svg>
                
                <div class="text-emerald-600 font-bold text-sm tracking-widest mb-2 uppercase">Phase 06</div>
                <h3 class="text-xl font-bold text-slate-900 mb-3">持續內容生成</h3>
                <p class="text-sm text-slate-600 leading-relaxed font-light">結合產業趨勢，定期自動產出具權威性 (E-E-A-T) 的長尾關鍵字文章，持續擴大流量池。</p>
            </div>

            <!-- Step 7 -->
            <div class="glass-card p-8 rounded-2xl group hover:-translate-y-2 transition-all duration-300 opacity-0 animate-fade-in-up delay-[700ms] relative overflow-hidden bg-white/70 hover:bg-white border-white/40 hover:shadow-xl hover:shadow-brand-500/10">
                <div class="absolute top-0 right-0 w-32 h-32 bg-amber-100 rounded-full blur-2xl group-hover:bg-amber-200 transition-colors"></div>
                
                <!-- Custom SVG Icon 7: Link Building -->
                <svg class="w-10 h-10 mb-6 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" />
                </svg>
                
                <div class="text-amber-600 font-bold text-sm tracking-widest mb-2 uppercase">Phase 07</div>
                <h3 class="text-xl font-bold text-slate-900 mb-3">外部連結建置</h3>
                <p class="text-sm text-slate-600 leading-relaxed font-light">AI 識別高權重相關網站，自動策劃數位公關與外部連結策略，快速提升網域權威度 (DA)。</p>
            </div>

            <!-- Step 8 -->
            <div class="glass-card p-8 rounded-2xl group hover:-translate-y-2 transition-all duration-300 opacity-0 animate-fade-in-up delay-[800ms] relative overflow-hidden bg-white/70 hover:bg-white border-white/40 hover:shadow-xl hover:shadow-brand-500/10">
                <div class="absolute top-0 right-0 w-32 h-32 bg-rose-100 rounded-full blur-2xl group-hover:bg-rose-200 transition-colors"></div>
                
                <!-- Custom SVG Icon 8: Conversion -->
                <svg class="w-10 h-10 mb-6 text-rose-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                
                <div class="text-rose-600 font-bold text-sm tracking-widest mb-2 uppercase">Phase 08</div>
                <h3 class="text-xl font-bold text-slate-900 mb-3">流量變現與轉換</h3>
                <p class="text-sm text-slate-600 leading-relaxed font-light">無縫整合表單與 CRM 系統，透過 A/B 測試持續優化著陸頁，將自然流量極大化轉為高質量名單。</p>
            </div>

        </div>
    </div>
</section>