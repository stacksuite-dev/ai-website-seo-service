---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import LeadForm from '../../components/LeadForm.astro';

const showcases = await getCollection('showcase');
---

<Layout title="AI SEO 專家實戰成功案例 | B2B 行銷">
    <Navigation />
    
    <main class="pt-32 pb-16 bg-slate-50 min-h-screen">
        <div class="max-w-7xl mx-auto px-6 lg:px-8">
            <header class="mb-16 text-center max-w-3xl mx-auto">
                <h1 class="text-4xl md:text-5xl font-display font-bold text-slate-900 mb-6 leading-tight">
                    實戰成功案例
                </h1>
                <p class="text-lg text-slate-600 font-light leading-relaxed">
                    見證 AI 驅動的 SEO 引擎如何翻轉各產業 B2B 企業營收，創造被動流量池。
                </p>
            </header>

            <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3 mb-20">
                {showcases.map(showcase => (
                    <a href={`/showcase/${showcase.id}`} class="glass-card rounded-2xl overflow-hidden group hover:-translate-y-1 transition-all duration-300 bg-white flex flex-col border border-slate-100 hover:shadow-xl hover:shadow-slate-300">
                        {showcase.data.screenshotUrl && (
                            <div class="aspect-[4/3] w-full overflow-hidden relative bg-slate-100">
                                <img 
                                    src={showcase.data.screenshotUrl} 
                                    alt={showcase.data.title}
                                    class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-700"
                                />
                            </div>
                        )}
                        <div class="p-8 flex-1 flex flex-col relative z-20 bg-white">
                            <div class="flex flex-wrap gap-2 mb-4 -mt-12">
                                <span class="px-3 py-1 bg-white border border-slate-200 text-slate-700 text-xs font-medium rounded-full shadow-sm">
                                    {showcase.data.industry}
                                </span>
                                <span class="px-3 py-1 bg-brand-500 text-white text-xs font-medium rounded-full shadow-sm uppercase">
                                    {showcase.data.style}
                                </span>
                            </div>
                            <h2 class="text-2xl font-bold text-slate-900 mb-3 line-clamp-2 group-hover:text-brand-600 transition-colors">
                                {showcase.data.title}
                            </h2>
                            <p class="text-slate-600 text-sm line-clamp-3 mb-6 font-light flex-1">
                                {showcase.data.description}
                            </p>
                            <div class="text-sm text-brand-600 font-bold flex items-center justify-end mt-auto group-hover:text-brand-700 transition-colors">
                                查看完整案例 <span class="ml-1 transform group-hover:translate-x-1 transition-transform">→</span>
                            </div>
                        </div>
                    </a>
                ))}
            </div>
            
        </div>
    </main>
    
    <LeadForm />
</Layout>